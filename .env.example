# Copy to .env and adjust. docker-compose reads these.

# Bearer token required by POST /ingest (used by the collector's remote mode).
INGEST_TOKEN=dev-ingest-token

# CORS origins for the API. Use the Vercel URL in production, or * locally.
CORS_ORIGINS=*

# --- Remote ingest (for seeding a deployed backend from your laptop) ---
# INGEST_URL=https://your-backend.up.railway.app
